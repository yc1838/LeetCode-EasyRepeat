{
    "manifest_version": 3,
    "name": "LeetCode EasyRepeat",
    "version": "1.0.1",
    "description": "Automatically capture LeetCode submissions and schedule spaced repetition reviews.",
    "icons": {
        "16": "src/assets/icons/icon16.png",
        "32": "src/assets/icons/icon32.png",
        "48": "src/assets/icons/icon48.png",
        "128": "src/assets/icons/icon128.png"
    },
    "permissions": [
        "storage",
        "alarms",
        "notifications"
    ],
    "host_permissions": [
        "https://leetcode.com/*",
        "https://leetcode.cn/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
    ],
    "options_ui": {
        "page": "dist/src/options/options.html",
        "open_in_tab": true
    },
    "action": {
        "default_icon": {
            "16": "src/assets/icons/icon16.png",
            "32": "src/assets/icons/icon32.png",
            "48": "src/assets/icons/icon48.png",
            "128": "src/assets/icons/icon128.png"
        },
        "default_popup": "dist/src/popup/popup.html",
        "default_title": "LeetCode EasyRepeat"
    },
    "background": {
        "service_worker": "dist/background.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": [
                "https://leetcode.com/problems/*"
            ],
            "js": [
                "src/algorithms/srs_logic.js",
                "src/shared/config.js",
                "src/shared/ui_i18n.js",
                "src/shared/problem_titles.js",
                "src/algorithms/fsrs_logic.js",
                "src/content/content_ui.js",
                "src/content/leetcode_dom.js",
                "src/shared/storage.js",
                "src/content/leetcode_api.js",
                "src/content/llm_sidecar.js",
                "src/content/content.js"
            ],
            "css": [
                "src/content/content.css",
                "src/content/llm_sidecar.css"
            ]
        }
    ]
}
